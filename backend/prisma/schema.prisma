generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model SiteConfig {
  id          Int    @id @default(autoincrement())
  siteName    String @default("WebGenerica")
  logo        String @default("")
  phone       String @default("")
  email       String @default("")
  address     String @default("")
  socialLinks Json   @default("{}")
  theme       Json   @default("{}")
  currency    String @default("$")
  heroBanner      Json   @default("{}")
  benefits        Json   @default("[]")
  shippingOptions  Json   @default("[]")
  servicioTecnico  Json   @default("{}")
  faq              Json   @default("{}")
  aboutPage        Json   @default("{}")
  contactPage      Json   @default("{}")
  instagramSection Json   @default("{}")
  promoBanner      Json   @default("{}")
  footerDescription String @default("")
  createdAt        DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String
  role      String    @default("customer")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  orders    Order[]
  cartItems CartItem[]
}

model Category {
  id       Int        @id @default(autoincrement())
  name     String
  slug     String     @unique
  image    String     @default("")
  parentId Int?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          Int              @id @default(autoincrement())
  name        String
  slug        String           @unique
  description String           @default("")
  price       Decimal          @db.Decimal(10, 2)
  salePrice   Decimal?         @db.Decimal(10, 2)
  stock       Int              @default(0)
  featured    Boolean          @default(false)
  active      Boolean          @default(true)
  categoryId  Int
  category    Category         @relation(fields: [categoryId], references: [id])
  images      ProductImage[]
  variants    ProductVariant[]
  cartItems   CartItem[]
  orderItems  OrderItem[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  url       String
  order     Int     @default(0)
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id          Int         @id @default(autoincrement())
  name        String
  value       String
  priceAdjust Decimal     @default(0) @db.Decimal(10, 2)
  stock       Int         @default(0)
  productId   Int
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems   CartItem[]
  orderItems  OrderItem[]
}

model CartItem {
  id        Int             @id @default(autoincrement())
  userId    Int
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int
  product   Product         @relation(fields: [productId], references: [id])
  variantId Int?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  quantity  Int             @default(1)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([userId, productId, variantId])
}

model Order {
  id              Int         @id @default(autoincrement())
  userId          Int?
  user            User?       @relation(fields: [userId], references: [id])
  guestEmail      String      @default("")
  guestName       String      @default("")
  status          String      @default("pending")
  total           Decimal     @db.Decimal(10, 2)
  shippingAddress Json        @default("{}")
  shippingOption  String      @default("")
  paymentMethod   String      @default("")
  paymentStatus   String      @default("pending")
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        Int             @id @default(autoincrement())
  orderId   Int
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int
  product   Product         @relation(fields: [productId], references: [id])
  variantId Int?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  quantity  Int
  unitPrice Decimal         @db.Decimal(10, 2)
}

model Coupon {
  id          Int       @id @default(autoincrement())
  code        String    @unique
  type        String    @default("percentage")
  value       Float
  minPurchase Float     @default(0)
  maxUses     Int       @default(0)
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
