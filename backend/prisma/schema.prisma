generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Multi-tenant: cada Tenant es una tienda con su propio dominio ───

model Tenant {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  domain    String?  @unique
  name      String
  status    String   @default("pending") // pending | active | suspended
  plan      String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  siteConfig SiteConfig?
  users      User[]
  categories Category[]
  products   Product[]
  orders     Order[]
  coupons    Coupon[]

  @@index([domain])
  @@index([status])
}

model SiteConfig {
  id          Int    @id @default(autoincrement())
  tenantId    Int    @unique
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siteName    String @default("WebGenerica")
  logo        String @default("")
  phone       String @default("")
  email       String @default("")
  address     String @default("")
  socialLinks Json   @default("{}")
  theme       Json   @default("{}")
  currency    String @default("$")
  heroBanner      Json   @default("{}")
  benefits        Json   @default("[]")
  shippingOptions  Json   @default("[]")
  servicioTecnico  Json   @default("{}")
  faq              Json   @default("{}")
  aboutPage        Json   @default("{}")
  contactPage      Json   @default("{}")
  instagramSection Json   @default("{}")
  promoBanner      Json   @default("{}")
  footerDescription String @default("")
  createdAt        DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  password        String
  name            String
  role            String    @default("customer") // super_admin | admin | customer
  tenantId        Int?
  tenant          Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  isActive        Boolean   @default(false)
  activationToken String?
  activatedAt     DateTime?
  suspendedAt     DateTime?
  suspendReason   String?
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  orders          Order[]
  cartItems       CartItem[]

  @@index([tenantId])
  @@index([role])
}

model Category {
  id       Int        @id @default(autoincrement())
  tenantId Int
  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  slug     String
  image    String     @default("")
  parentId Int?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Product {
  id          Int              @id @default(autoincrement())
  tenantId    Int
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String           @default("")
  price       Decimal          @db.Decimal(10, 2)
  salePrice   Decimal?         @db.Decimal(10, 2)
  stock       Int              @default(0)
  featured    Boolean          @default(false)
  active      Boolean          @default(true)
  categoryId  Int
  category    Category         @relation(fields: [categoryId], references: [id])
  images      ProductImage[]
  variants    ProductVariant[]
  cartItems   CartItem[]
  orderItems  OrderItem[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, active])
  @@index([tenantId, featured])
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  url       String
  order     Int     @default(0)
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id          Int         @id @default(autoincrement())
  name        String
  value       String
  priceAdjust Decimal     @default(0) @db.Decimal(10, 2)
  stock       Int         @default(0)
  productId   Int
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems   CartItem[]
  orderItems  OrderItem[]
}

model CartItem {
  id        Int             @id @default(autoincrement())
  tenantId  Int
  userId    Int
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int
  product   Product         @relation(fields: [productId], references: [id])
  variantId Int?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  quantity  Int             @default(1)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([userId, productId, variantId])
  @@index([tenantId])
}

model Order {
  id              Int         @id @default(autoincrement())
  tenantId        Int
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId          Int?
  user            User?       @relation(fields: [userId], references: [id])
  guestEmail      String      @default("")
  guestName       String      @default("")
  status          String      @default("pending")
  total           Decimal     @db.Decimal(10, 2)
  shippingAddress Json        @default("{}")
  shippingOption  String      @default("")
  paymentMethod   String      @default("")
  paymentStatus   String      @default("pending")
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
}

model OrderItem {
  id        Int             @id @default(autoincrement())
  orderId   Int
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int
  product   Product         @relation(fields: [productId], references: [id])
  variantId Int?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  quantity  Int
  unitPrice Decimal         @db.Decimal(10, 2)
}

model Coupon {
  id          Int       @id @default(autoincrement())
  tenantId    Int
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code        String
  type        String    @default("percentage")
  value       Float
  minPurchase Float     @default(0)
  maxUses     Int       @default(0)
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  entity    String
  entityId  Int?
  tenantId  Int?
  details   Json     @default("{}")
  ip        String   @default("")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tenantId])
  @@index([action])
}
